# === ANE Backend Environment Variables ===

# OpenRouter API Key (get from openrouter.ai - free tier available)
# This is the primary LLM gateway. ANE tries these free models in order:
# llama-3.1-8b-instruct -> mistral-7b -> gemma-2-9b -> phi-3-mini -> qwen-2-7b
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Direct fallback API (used if ALL OpenRouter models fail)
# Can be Anthropic, OpenAI, or any OpenAI-compatible endpoint
FALLBACK_API_KEY=
FALLBACK_BASE_URL=https://api.openai.com/v1
FALLBACK_MODEL=gpt-4o-mini

# Zep Memory (optional, get from app.getzep.com - free tier)
ZEP_API_KEY=

# Agent simulation settings
DEFAULT_AGENT_COUNT=20
MAX_AGENT_COUNT=100

# CORS - set to your Vercel frontend URL in production
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
